# Preimenuj v .env in vnesi svoje podatke.

# --- ntfy.sh (priporoceno, brezplacno) ---
# 1) Nalozi app "ntfy" (Play Store / App Store)
# 2) V appu klikni + in vnesi unikatno SKRIVNO ime kanala
#    (mora biti dovolj nakljucno, ker je javno dostopno komurkoli ki ga ugane)
# 3) Vnesi isto ime spodaj:
NTFY_TOPIC=posesti-zamenjaj-z-nakljucnim
NTFY_SERVER=

# --- Telegram (alternativa) ---
TG_BOT_TOKEN=
TG_CHAT_ID=

# --- Email (alternativa, fallback) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_TO=
